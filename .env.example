# Copy to ".env.local" (gitignored) and fill from Supabase:
# Dashboard → Project Settings → API
#
# Vite only exposes env vars that start with VITE_
# Use the project URL and a public client key — not the service_role secret.
# Set either the legacy anon JWT or the newer publishable key (not both required).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
