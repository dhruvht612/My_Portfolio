# Vite (browser) — required for Supabase-backed portfolio + admin
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional aliases (see src/lib/supabase.js)
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Admin System health page: probe this origin for “Frontend” (defaults to current site origin)
# VITE_HEALTH_CHECK_ORIGIN=https://your-production-domain.com

# Optional: shown on Admin → System health (build or release tag)
# VITE_APP_VERSION=1.0.0

# Optional: backend API health (GET /health or GET /); enables API card on System health
# VITE_API_URL=https://api.example.com

# Contact form: submissions go to Supabase table `contact_submissions` (anon INSERT via RLS; see docs/backend-integration-plan.md). Email notifications are not sent automatically—use webhooks or an email provider if you need them.

# Node seed script only — never commit real keys; never bundle into Vite client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local Node scripts only (seed / verify:phase5 / migrate-assets). If you see
# UNABLE_TO_VERIFY_LEAF_SIGNATURE (antivirus HTTPS scan), set to 1. Never in production CI.
# SUPABASE_DEV_INSECURE_TLS=1
