# Vite (browser) — required for portfolio data + contact form + admin
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional: connect frontend to backend CMS API (projects, skills, certifications, experience)
# When set, the portfolio loads content from the API instead of only local src/data
# VITE_API_URL=http://localhost:4000

# Optional: URL of the admin portal (shown in footer when VITE_API_URL is set)
# VITE_ADMIN_URL=http://localhost:3000
